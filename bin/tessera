#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Tessera CLI — AI-Native CMS Installer
 *
 * Usage:
 *   tessera new {directory}    Create a new Tessera project
 *   tessera tools              Show available AI tools
 *   tessera --version          Show version
 *   tessera --help             Show help
 *
 * Install globally:
 *   composer global require tessera/installer
 */

// Autoloader: support both global install and local dev
$autoloaders = [
    __DIR__ . '/../vendor/autoload.php',           // local dev
    __DIR__ . '/../../autoload.php',                // global install (vendor/bin)
    __DIR__ . '/../../../autoload.php',             // global install (deeper)
];

$loaded = false;

foreach ($autoloaders as $autoloader) {
    if (file_exists($autoloader)) {
        require $autoloader;
        $loaded = true;

        break;
    }
}

if (! $loaded) {
    // Fallback: manual require for standalone usage without composer autoload
    $src = dirname(__DIR__) . '/src';
    require $src . '/AiResponse.php';
    require $src . '/AiTool.php';
    require $src . '/Complexity.php';
    require $src . '/Cli/NewCommandArgs.php';
    require $src . '/Cli/ProjectDirectoryName.php';
    require $src . '/ToolSelection.php';
    require $src . '/ToolRouter.php';
    require $src . '/Console.php';
    require $src . '/SystemInfo.php';
    require $src . '/Memory.php';
    require $src . '/StepRunner.php';
    require $src . '/NewCommand.php';
}

use Tessera\Installer\AiTool;
use Tessera\Installer\Cli\ProjectDirectoryName;
use Tessera\Installer\Console;
use Tessera\Installer\NewCommand;
use Tessera\Installer\SystemInfo;
use Tessera\Installer\ToolRouter;

// ─── Parse arguments ───

$args = array_slice($argv, 1);
$command = $args[0] ?? null;

// ─── Version ───

if ($command === '--version' || $command === '-v') {
    Console::line('Tessera Installer ' . installerVersion());
    exit(0);
}

// ─── Help ───

if ($command === '--help' || $command === '-h' || $command === null) {
    showHelp();
    exit(0);
}

// ─── Tools ───

if ($command === 'tools') {
    showTools();
    exit(0);
}

// ─── Doctor ───

if ($command === 'doctor') {
    showDoctor();
    exit(0);
}

// ─── Plan subcommands (compile / show / diff) ───

if ($command === 'plan') {
    $sub = $args[1] ?? null;
    $rest = array_slice($args, 2);

    $registry = [
        'compile' => \Tessera\Installer\Commands\PlanCompileCommand::class,
        'show' => \Tessera\Installer\Commands\PlanShowCommand::class,
        'diff' => \Tessera\Installer\Commands\PlanDiffCommand::class,
    ];

    if ($sub === null || $sub === '--help' || $sub === '-h') {
        Console::line();
        Console::bold('tessera plan — work with compiled plan.json artifacts');
        Console::line();
        foreach ($registry as $name => $class) {
            $cmd = new $class;
            Console::line(sprintf('  %-10s  %s', $name, $cmd->description()));
        }
        Console::line();
        exit(0);
    }

    if (! isset($registry[$sub])) {
        Console::error("Unknown plan subcommand: {$sub}");
        Console::line('Use: tessera plan --help');
        exit(1);
    }

    $cmd = new $registry[$sub];
    exit($cmd->run($rest));
}

// ─── New project ───

if ($command === 'new') {
    $newArgs = array_slice($args, 1);
    $parsed = \Tessera\Installer\Cli\NewCommandArgs::parse($newArgs);

    if ($parsed->directory === null) {
        $invalidDirectoryLikeArg = firstInvalidDirectoryLikeArg($newArgs);
        if ($invalidDirectoryLikeArg !== null) {
            Console::error('Invalid directory name: '.ProjectDirectoryName::validate($invalidDirectoryLikeArg));
            exit(1);
        }

        Console::error('Missing directory name.');
        Console::line('Usage: tessera new {project-name}');
        exit(1);
    }

    $directoryError = ProjectDirectoryName::validate($parsed->directory);
    if ($directoryError !== null) {
        Console::error('Invalid directory name: '.$directoryError);
        exit(1);
    }

    $cmd = new NewCommand(
        $parsed->directory,
        $parsed->force,
        $parsed->forcedStack,
        $parsed->requirementsFixturePath,
    );
    exit($cmd->run());
}

// ─── Unknown command ───

Console::error("Unknown command: {$command}");
Console::line('Use: tessera --help');
exit(1);

// ─── Functions ───

function showHelp(): void
{
    Console::line();
    Console::cyan('  TESSERA — AI-Native CMS Installer');
    Console::line();
    Console::line('  Usage:');
    Console::line('    tessera new {project-name}                       Create a new Tessera project');
    Console::line('    tessera new {project-name} --force               Overwrite existing directory');
    Console::line('    tessera new {project-name} --stack=<name>        Skip AI stack selection');
    Console::line('    tessera new {project-name} --requirements-fixture=<path>  Skip interactive Q&A');
    Console::line('    tessera doctor                       Check if everything is ready');
    Console::line('    tessera tools                        Show available AI tools');
    Console::line('    tessera plan compile <yaml> [-o]     Compile a stack manifest to plan.json');
    Console::line('    tessera plan show [<plan.json>]      Show what a compiled plan will do');
    Console::line('    tessera plan diff <a.json> <b.json>  Semantic diff between two plans');
    Console::line('    tessera --version                    Version');
    Console::line('    tessera --help                       This message');
    Console::line();
    Console::line('  Example:');
    Console::cyan('    tessera new my-restaurant');
    Console::line();
    Console::line('  AI will ask what you need and build the project.');
    Console::line('  Requires PHP 8.4+ and at least one AI CLI (claude, gemini, codex).');
    Console::line();
}

function firstInvalidDirectoryLikeArg(array $args): ?string
{
    $valueFlags = ['--stack', '--requirements-fixture'];
    $booleanFlags = ['--force', '-f'];
    $skipNext = false;

    foreach ($args as $arg) {
        if ($skipNext) {
            $skipNext = false;

            continue;
        }

        if (in_array($arg, $valueFlags, true)) {
            $skipNext = true;

            continue;
        }

        if (in_array($arg, $booleanFlags, true)
            || str_starts_with($arg, '--stack=')
            || str_starts_with($arg, '--requirements-fixture=')
        ) {
            continue;
        }

        if (str_starts_with($arg, '-')) {
            return $arg;
        }
    }

    return null;
}

function showTools(): void
{
    Console::line();
    Console::bold('Available AI tools:');
    Console::line();

    $tools = AiTool::detectAll();

    if (empty($tools)) {
        Console::error('No AI tools found!');
        Console::line();
        Console::line('Install at least one:');
        Console::line('  claude — https://docs.anthropic.com/en/docs/claude-code');
        Console::line('  gemini — https://ai.google.dev/gemini-api/docs/cli');
        Console::line('  codex  — https://github.com/openai/codex');

        return;
    }

    foreach ($tools as $name => $info) {
        Console::success("{$name}: {$info['version']}");
    }

    Console::line();

    $router = ToolRouter::detect();
    if ($router !== null) {
        Console::bold('Intelligent routing:');
        Console::line($router->describe());
        Console::line();
    }
}

function installerVersion(): string
{
    // Try git tag first (works in dev and when installed from source)
    $installerDir = str_replace('\\', '/', dirname(__DIR__));
    $result = [];
    $exit = 1;
    exec('git -C "' . $installerDir . '" describe --tags --abbrev=0 2>&1', $result, $exit);

    if ($exit === 0 && ! empty($result[0])) {
        return trim($result[0]);
    }

    // Fallback: check composer installed.json (global install via composer)
    $installed = dirname(__DIR__, 3) . '/composer/installed.json';
    if (is_file($installed)) {
        $data = json_decode((string) file_get_contents($installed), true);
        $packages = $data['packages'] ?? $data;
        foreach ($packages as $pkg) {
            if (($pkg['name'] ?? '') === 'tessera/installer') {
                return $pkg['version'] ?? 'dev';
            }
        }
    }

    return 'dev';
}

function showDoctor(): void
{
    $system = SystemInfo::detect();

    Console::line();
    Console::cyan('  TESSERA DOCTOR — System Check');
    Console::line();

    Console::bold("System:");
    Console::line("  OS: {$system->os()}");
    Console::line("  Package manager: {$system->packageManager()}");
    Console::line();

    $allGood = true;

    Console::bold("Required:");

    // PHP
    if ($system->hasTool('php')) {
        Console::success("PHP — {$system->toolVersion('php')}");
    } else {
        Console::fail('PHP — not found (need 8.4+)');
        $allGood = false;
    }

    // Composer
    if ($system->hasTool('composer')) {
        Console::success("Composer — {$system->toolVersion('composer')}");
    } else {
        Console::fail('Composer — not found');
        $allGood = false;
    }

    Console::line();
    Console::bold("AI tools (need at least one):");

    $aiTools = AiTool::detectAll();
    if (empty($aiTools)) {
        Console::fail('No AI tools found!');
        Console::line('  Install one:');
        Console::line('    npm install -g @anthropic-ai/claude-code');
        Console::line('    npm install -g @google/gemini-cli');
        Console::line('    npm install -g @openai/codex');
        $allGood = false;
    } else {
        foreach ($aiTools as $name => $info) {
            Console::success("{$name} — {$info['version']}");
        }
    }

    Console::line();
    Console::bold("Optional (depends on stack):");

    $optional = ['node' => 'Node.js', 'go' => 'Go', 'flutter' => 'Flutter', 'dart' => 'Dart', 'docker' => 'Docker', 'git' => 'Git'];
    foreach ($optional as $tool => $label) {
        if ($system->hasTool($tool)) {
            Console::success("{$label} — {$system->toolVersion($tool)}");
        } else {
            Console::line("  \033[90m{$label} — not installed\033[0m");
        }
    }

    Console::line();

    // Disk space
    $freeBytes = disk_free_space(getcwd() ?: '.');
    if ($freeBytes !== false) {
        $freeGb = round($freeBytes / 1073741824, 1);
        if ($freeGb >= 1) {
            Console::success("Disk space: {$freeGb} GB free");
        } else {
            Console::warn("Disk space: {$freeGb} GB free — might be tight");
        }
    }

    Console::line();

    if ($allGood) {
        Console::cyan('  All good! Run: tessera new my-project');
    } else {
        Console::error('  Fix the issues above and try again.');
    }

    Console::line();
}
