{
    "name": "tessera/installer",
    "description": "Tessera AI-Native CMS Installer — AI builds your project",
    "keywords": ["tessera", "cms", "ai", "installer", "laravel"],
    "license": "PolyForm-Noncommercial-1.0.0",
    "type": "project",
    "require": {
        "php": "^8.4",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.27"
    },
    "autoload": {
        "psr-4": {
            "Tessera\\Installer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tessera\\Installer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "bin": ["bin/tessera"],
    "minimum-stability": "stable",
    "prefer-stable": true
}
